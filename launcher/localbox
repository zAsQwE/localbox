#!/usr/bin/env bash
#
# LocalBox — точка входа (запуск из папки launcher).
#   ./localbox                      — GUI (десктоп)
#   ./localbox -ip=1.2.3.4          — сервер без GUI на этом адресе
#   ./localbox -ip=1.2.3.4 -no-web  — сервер без раздачи веб-клиента
#   ./localbox --check              — проверка окружения
#
set -e
DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
cd "$DIR"
PY="$(command -v python3 || command -v python || true)"
if [ -z "$PY" ]; then
    echo "Не найден python3. На большинстве Linux он уже есть; иначе поставьте python3."
    exit 1
fi
exec "$PY" localbox_launcher.py "$@"
